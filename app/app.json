{
  "expo": {
    "name": "WEROL",
    "slug": "werol-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "werol",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0c0c0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.werol.app"
    },
    "android": {
      "package": "com.werol.app",
      "adaptiveIcon": {
        "backgroundColor": "#0c0c0a"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "d487033e-74be-4208-8fa1-46241f7f29ed"
      }
    },
    "owner": "mkacmar",
    "updates": {
      "url": "https://u.expo.dev/d487033e-74be-4208-8fa1-46241f7f29ed"
    }
  }
}
